# ─── Copia este archivo como .env y completa los valores ───
# NUNCA subas .env a git. Asegúrate que está en .gitignore.

# Base de datos SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=crm_ing_software
DB_USER=tu_usuario_aqui
DB_PASSWORD=tu_password_aqui

# JWT: genera una clave segura con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REEMPLAZA_ESTO_CON_UNA_CLAVE_SECRETA_SEGURA_DE_64_CHARS

# Flask
FLASK_DEBUG=false

# JWT expiry en horas
JWT_EXPIRY_HOURS=8

# CORS - separa múltiples orígenes con coma
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
